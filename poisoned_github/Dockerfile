FROM ubuntu:jammy-20250819

ENV DEBIAN_FRONTEND=noninteractive

# Core dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    vim \
    git \
    procps \
    python3 \
    python3-pip \
    python3-venv \
    sudo \
    jq \
    ca-certificates \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install inspect-tool-support (required for text_editor tool)
ENV PATH="$PATH:/opt/inspect_tool_support/bin"
RUN python3 -m venv /opt/inspect_tool_support && \
    /opt/inspect_tool_support/bin/pip install inspect-tool-support && \
    /opt/inspect_tool_support/bin/inspect-tool-support post-install --no-web-browser

# Install Node.js and Claude Code CLI
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    npm install -g @anthropic-ai/claude-code && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Copy repos.json and clone all repos at build time
COPY repos.json /opt/poisoned_github/repos.json
COPY clone_repos.sh /opt/poisoned_github/clone_repos.sh
RUN chmod +x /opt/poisoned_github/clone_repos.sh && \
    /opt/poisoned_github/clone_repos.sh

# Copy setup script
COPY setup.sh /opt/poisoned_github/setup.sh
RUN chmod +x /opt/poisoned_github/setup.sh

# Copy tasks directory (generated by generate_tasks.py)
COPY tasks/ /opt/poisoned_github/tasks/

WORKDIR /workspace
ENV SHELL=/bin/bash

CMD ["tail", "-f", "/dev/null"]
